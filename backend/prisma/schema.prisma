  machine_name      String?
  model_name        String?
  pc_target         Int
  cycle_time_target Float
  eff_target        Float
  target_07         Int?     @default(0)
  target_08         Int?     @default(0)
  target_09         Int?     @default(0)
  target_10         Int?     @default(0)
  target_11         Int?     @default(0)
  target_12         Int?     @default(0)
