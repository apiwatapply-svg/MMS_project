model tb_oee {
  id           Int      @id @default(autoincrement())
  date         DateTime @db.Date
  machine_name String
  oee_value    Float?   @default(0)
  availability Float?   @default(0)
  ng_qty       Int?     @default(0)
  performance  Float?   @default(0)
  quality      Float?   @default(0)

  @@unique([machine_name, date])
  @@index([date])
}

model tb_history_working {
  id           Int           @id @default(autoincrement())
  date         DateTime      @db.Date
  machine_name String
  emp_no       String?
  shift        String
  start_time   DateTime
  end_time     DateTime?
  tbm_operator tbm_operator? @relation(fields: [emp_no], references: [emp_no])

  @@index([machine_name, date])
  @@index([emp_no])
}

model tb_MCStatus {
  ID       BigInt   @id(map: "PK_tb_MCStatus") @default(autoincrement())
  Datetime DateTime
  MC       String   @db.NVarChar(50)
  MCStatus String   @db.NVarChar(50)
  UTC_Time DateTime?
  Remark   String?  @db.NVarChar(255)

  @@index([Datetime])
}

model tb_MCAlarm {
  ID       BigInt   @id(map: "PK_tb_MCAlarm") @default(autoincrement())
  Datetime DateTime
  MC       String   @db.NVarChar(50)
  MCAlarm String   @db.NVarChar(255)
  UTC_Time DateTime?

  @@index([Datetime])
}

model tb_machine_plan_config {
  id                Int      @id @default(autoincrement())
  machine_name      String   @unique
  eff_target        Float
  cycle_time_target Float
  process_name      String?
  model_name        String?
  model_type        String?
  active_hours      String
  updated_at        DateTime @default(now()) @updatedAt
  oee_mode          String   @default("manual") @db.NVarChar(10)
}

model tb_machine_holiday {
  id           Int      @id @default(autoincrement())
  machine_name String
  holiday_date DateTime @db.Date
  created_at   DateTime @default(now())

  @@unique([machine_name, holiday_date])
  @@index([machine_name])
}

model tbm_machine_station {
  id             Int      @id @default(autoincrement())
  machine_name   String
  ng_id          Int
  station_number Int
  station_name   String
  status         String   @default("active")
  created_at     DateTime @default(now())
  updated_at     DateTime @default(now())

  @@index([machine_name])
}

model tb_machine_ng {
  id           Int      @id @default(autoincrement())
  date         DateTime @db.Date
  machine_name String
  station_id   Int      // ✅ FK to tbm_machine_station.id (required)
  ng_07        Int?     @default(0)
  ng_08        Int?     @default(0)
  ng_09        Int?     @default(0)
  ng_10        Int?     @default(0)
  ng_11        Int?     @default(0)
  ng_12        Int?     @default(0)
  ng_13        Int?     @default(0)
  ng_14        Int?     @default(0)
  ng_15        Int?     @default(0)
  ng_16        Int?     @default(0)
  ng_17        Int?     @default(0)
  ng_18        Int?     @default(0)
  ng_19        Int?     @default(0)
  ng_20        Int?     @default(0)
  ng_21        Int?     @default(0)
  ng_22        Int?     @default(0)
  ng_23        Int?     @default(0)
  ng_00        Int?     @default(0)
  ng_01        Int?     @default(0)
  ng_02        Int?     @default(0)
  ng_03        Int?     @default(0)
  ng_04        Int?     @default(0)
  ng_05        Int?     @default(0)
  ng_06        Int?     @default(0)
  Overall_ng   Int?     @default(0)

  @@unique([machine_name, date, station_id])
  @@index([machine_name, date])
  @@index([date])
}


/// The underlying table does not contain a valid unique identifier and can therefore currently not be handled by Prisma Client.
model tb_MCStatus_Duration {
  MachineName String   @db.NVarChar(50)
  ModelName   String?  @db.NVarChar(50)
  StateName   String   @db.NVarChar(100)
  StartTime   DateTime @db.DateTime
  EndTime     DateTime @db.DateTime
  Duration    DateTime @db.Time
  Criteria    String?  @db.NVarChar(255)
  Reason      String?  @db.NVarChar(255)

  @@ignore
}

/// The underlying table does not contain a valid unique identifier and can therefore currently not be handled by Prisma Client.
model tb_MCStatus_Sum {
  ID                  Int       @default(autoincrement())
  FactoryDate         DateTime? @db.Date
  MachineName         String?   @db.NVarChar(50)
  ModelName           String?   @db.NVarChar(50)
  Signal_Lost         DateTime? @db.Time
  MM_Repair           DateTime? @db.Time
  Setter_Check_Master DateTime? @db.Time
  Prod_Check_Master   DateTime? @db.Time
  MM_Preventive       DateTime? @db.Time
  QC_Qualify          DateTime? @db.Time
  Break_Time          DateTime? @db.Time
  MM_Check_Master     DateTime? @db.Time
  QC_Check_Master     DateTime? @db.Time
  Plan_Stop           DateTime? @db.Time
  Setter_Adjust       DateTime? @db.Time
  Prod_Cleaning       DateTime? @db.Time
  Job_Done            DateTime? @db.Time
  Setter_Preventive   DateTime? @db.Time
  Wait_Part           DateTime? @db.Time
  Run_Time            DateTime? @db.Time
  MC_Stop             DateTime? @db.Time
  MC_Alarm            DateTime? @db.Time
  Cut_Lot             DateTime? @db.Time

  @@ignore
}

