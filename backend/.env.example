# Database connection string for SQL Server
# Format: sqlserver://USER:PASSWORD@HOST:PORT/DATABASE?schema=dbo
DATABASE_URL="sqlserver://username:password@localhost:1433/database_name?schema=dbo"

# Keep false for SQL-only portfolio mode.
# Set true when running the MQTT/InfluxDB simulator or connecting to a real machine network.
ENABLE_MACHINE_IO=false

# MQTT broker used by backend/services/mqttService.js and scripts/simulate_machine_mqtt.py
MQTT_URL="mqtt://127.0.0.1:1883"

# InfluxDB 1.x used by backend/services/influxService.js
INFLUX_HOST="127.0.0.1"
INFLUX_PORT="8086"
INFLUX_DATABASE="machine_db"
INFLUX_MEASUREMENT="data_tb"

# Optional HTTP URL used by the Python simulator for InfluxDB writes.
INFLUX_URL="http://127.0.0.1:8086"
